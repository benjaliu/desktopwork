### 5.6 AI 层（Claude Code SDK 封装）

#### 5.6.1 AgentService（`src/ai/agent-service.ts`）

**核心职责：封装 Claude Code Agent SDK，对外提供统一的 Agent 调用接口。**

```typescript
import { query, type Options } from '@anthropic-ai/claude-code';
import type { AgentMessage, AgentStreamEvent } from './types.js';

export interface AgentCallOptions {
  prompt: string;
  sessionId?: string;              // 多轮对话时传入
  systemPrompt?: string;
  allowedTools?: string[];         // ['Read', 'Edit', 'Bash', ...]
  model?: string;
  abortSignal?: AbortSignal;
}

export class AgentService {
  /** 流式调用 Agent */
  async *stream(options: AgentCallOptions): AsyncGenerator<AgentStreamEvent> {
    const opts: Options = {
      model: options.model ?? 'claude-sonnet-4-6',
      systemPrompt: options.systemPrompt,
      allowedTools: options.allowedTools ?? ['Read', 'Edit', 'Bash', 'Grep', 'Glob'],
      resume: options.sessionId,  // 续接会话
    };

    for await (const message of query({
      prompt: options.prompt,
      options: opts,
    }, { signal: options.abortSignal })) {
      // 转换 SDK 消息为统一事件格式
      yield this.convertToStreamEvent(message);
    }
  }

  /** 非流式调用（返回完整结果） */
  async call(options: AgentCallOptions): Promise<AgentMessage> {
    let lastMessage: AgentMessage | null = null;
    for await (const event of this.stream(options)) {
      if (event.type === 'message_end') {
        lastMessage = event.message;
      }
    }
    if (!lastMessage) throw new Error('No message received');
    return lastMessage;
  }

  private convertToStreamEvent(sdkMessage: any): AgentStreamEvent {
    // 转换 SDK 消息格式到平台统一事件格式
    // ... 类型映射
  }
}
```

**统一事件类型：**

```typescript
type AgentStreamEvent =
  | { type: 'message_start'; message: AgentMessage }
  | { type: 'text_delta'; delta: string; contentIndex: number }
  | { type: 'tool_use'; id: string; name: string; args: unknown }
  | { type: 'tool_result'; id: string; result: unknown }
  | { type: 'message_end'; message: AgentMessage; sessionId: string };
```

#### 5.6.2 SessionStore（`src/ai/session-store.ts`）

**职责：管理与 Agent 会话相关的本地状态。**

```typescript
import { readFile, appendFile, existsSync, mkdirSync } from 'node:fs';
import { join, dirname } from 'node:path';

export class SessionStore {
  /** 获取会话历史 */
  async getMessages(sessionKey: string): Promise<AgentMessage[]> {
    const file = this.getFilePath(sessionKey);
    if (!existsSync(file)) return [];
    const raw = await readFile(file, 'utf-8');
    return raw.trim().split('\n').filter(Boolean).map(JSON.parse);
  }

  /** 追加消息 */
  async appendMessage(sessionKey: string, message: AgentMessage): Promise<void> {
    const file = this.getFilePath(sessionKey);
    const dir = dirname(file);
    if (!existsSync(dir)) mkdirSync(dir, { recursive: true });
    await appendFile(file, JSON.stringify(message) + '\n');
  }

  private getFilePath(sessionKey: string): string {
    return join(this.dataDir, 'sessions', `${sessionKey}.jsonl`);
  }
}
```

**注意：** Claude Code SDK 自带 session 管理（`session_id`），用于续接多轮对话。我们本地存储的是「平台视角」的会话历史（用于 UI 显示和回溯），SDK 内部 session 由 Claude Code 自己管理。

### 5.7 Skills 系统

**MVP 阶段简化：** Skills 由 Claude Code SDK 内置提供（`allowedTools` 字段控制）。

**架构（v0.2+）：**

