## 五、核心模块设计

### 5.1 入口与路由（`src/index.ts` + `src/router.ts`）

**入口 `index.ts` 职责：**

```typescript
// 伪代码
import { createPlatform } from './platform/index.js';
import { createAppRegistry } from './platform/app-registry.js';
import { botChatApp } from './apps/bot-chat/index.js';
import { settingsApp } from './apps/settings/index.js';
import { loadConfig } from './platform/config.js';

const config = loadConfig();
const platform = createPlatform(config);
const registry = createAppRegistry(platform);

// 注册内置 App
registry.register(botChatApp);
registry.register(settingsApp);

const app = createRouter({ platform, registry });
app.listen(config.port, config.host);
```

**路由结构：**

```
/api/platform/*       — 平台 API（所有 App 共享）
  /api/platform/config
  /api/platform/memory
  /api/platform/skills
  /api/platform/apps

/api/:appId/*         — 各 App 自己的 API
  /api/bot-chat/chat        — 流式对话
  /api/bot-chat/sessions
  /api/settings/*

/apps/:appId/         — 各 App 的前端静态文件
  /apps/bot-chat/index.html
  /apps/settings/index.html
```

### 5.2 App 注册表（`src/platform/app-registry.ts`）

**App 接口定义：**

```typescript
interface AppManifest {
  id: string;                   // 'bot-chat'
  name: string;                 // 'Bot Chat'
  version: string;
  icon?: string;                // 图标 URL
  defaultRoute: string;         // '/'
  permissions: string[];        // 平台权限
}

interface AppModule {
  manifest: AppManifest;
  routes: Router;               // Express Router
  staticPath?: string;          // 前端静态文件目录
  initialize?(platform: Platform): Promise<void>;
  shutdown?(): Promise<void>;
}
```

**注册表行为：**

```typescript
class AppRegistry {
  register(app: AppModule): void;
  unregister(appId: string): void;
  get(appId: string): AppModule | undefined;
  list(): AppManifest[];
  
  // 路由挂载
  mountApi(app: Express): void {
    for (const app of this.apps.values()) {
      app.use(`/api/${app.manifest.id}`, app.routes);
    }
  }
  
  mountStatic(app: Express): void {
    for (const app of this.apps.values()) {
      if (app.staticPath) {
        app.use(`/apps/${app.manifest.id}`, express.static(app.staticPath));
      }
    }
  }
}
```

