{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DesktopWork",
  "version": "0.1.0",
  "identifier": "com.benjamin.desktopwork",
  "build": {},
  "app": {
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "server"
    ],
    "externalBin": [
      "../node-binaries/node"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}