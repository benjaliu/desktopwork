{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DesktopWork",
  "version": "0.1.0",
  "identifier": "com.benjamin.desktopwork",
  "build": {},
  "app": {
    "windows": [
      {
        "title": "DesktopWork",
        "width": 900,
        "height": 700,
        "minWidth": 600,
        "minHeight": 400,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}